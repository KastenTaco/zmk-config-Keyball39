
#define DEF 0
#define GAM 1
#define NAV 4
#define MOU 5
#define SYM 6
#define NUM 7
#define FUN 8


#include <behaviors/mouse_keys.dtsi>
#include <dt-bindings/zmk/mouse.h>
#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>
#include "helpers.h"

// Combos

#undef COMBO_HOOK
#define COMBO_HOOK
#define COMBO_TERM_FAST 10
#define COMBO_TERM_SLOW 50

// CAPS WORD
// -----------------------------------------------------------------------------------------
// tap      |   Q   |   W   |   E   |   R   |   T   |   |   Y   |   U   |   I   |   O   |   P   |
//          _____________________________________________________________________________________
// tap      |   A   |   S   |   D   |XXXFXXX|   G   |   |   H   |XXXJXXX|   K   |   L   |   ;   |
//          _____________________________________________________________________________________
// tap      |   Z   |   X   |   C   |   V   |   B   |   |   N   |   M   |   ,   |   .   |   /   |
//
// tap                      |  ESC  |  ENT  |  TAB  |   | BSPC  |  SPC  |  DEL  |
ZMK_COMBO(caps, &caps_word, LM3 RM3, DEF, COMBO_TERM_SLOW)

&caps_word {
    continue-list = <UNDERSCORE MINUS>;
};

// REFRESH (F5)
// -----------------------------------------------------------------------------------------
// tap      |XXXQXXX|XXXWXXX|   E   |   R   |   T   |   |   Y   |   U   |   I   |   O   |   P   |
//          _____________________________________________________________________________________
// tap      |   A   |   S   |   D   |   F   |   G   |   |   H   |   J   |   K   |   L   |   ;   |
//          _____________________________________________________________________________________
// tap      |   Z   |   X   |   C   |   V   |   B   |   |   N   |   M   |   ,   |   .   |   /   |
//
// tap                      |  ESC  |  ENT  |  TAB  |   | BSPC  |  SPC  |  DEL  |
ZMK_COMBO(refr, &kp F5, LT0 LT1, DEF, COMBO_TERM_FAST)        

// PASTE
// -----------------------------------------------------------------------------------------
// tap      |   Q   |   W   |   E   |   R   |   T   |   |   Y   |   U   |   I   |   O   |   P   |
//          _____________________________________________________________________________________
// tap      |   A   |   S   |   D   |   F   |   G   |   |   H   |   J   |   K   |   L   |   ;   |
//          _____________________________________________________________________________________
// tap      |   Z   |   X   |   C   |XXXVXXX|XXXBXXX|   |   N   |   M   |   ,   |   .   |   /   |
//
// tap                      |  ESC  |  ENT  |  TAB  |   | BSPC  |  SPC  |  DEL  |
ZMK_COMBO(paste, &kp LC(V), LB3 LB4, DEF, COMBO_TERM_SLOW)

// COPY
// -----------------------------------------------------------------------------------------
// tap      |   Q   |   W   |   E   |   R   |   T   |   |   Y   |   U   |   I   |   O   |   P   |
//          _____________________________________________________________________________________
// tap      |   A   |   S   |   D   |   F   |   G   |   |   H   |   J   |   K   |   L   |   ;   |
//          _____________________________________________________________________________________
// tap      |   Z   |   X   |XXXCXXX|XXXVXXX|   B   |   |   N   |   M   |   ,   |   .   |   /   |
//
// tap                      |  ESC  |  ENT  |  TAB  |   | BSPC  |  SPC  |  DEL  |
ZMK_COMBO(copy, &kp LC(C), LB2 LB3, DEF, COMBO_TERM_SLOW)

// CUT
// -----------------------------------------------------------------------------------------
// tap      |   Q   |   W   |   E   |   R   |   T   |   |   Y   |   U   |   I   |   O   |   P   |
//          _____________________________________________________________________________________
// tap      |   A   |   S   |   D   |   F   |   G   |   |   H   |   J   |   K   |   L   |   ;   |
//          _____________________________________________________________________________________
// tap      |   Z   |XXXXXXX|XXXCXXX|   V   |   B   |   |   N   |   M   |   ,   |   .   |   /   |
//
// tap                      |  ESC  |  ENT  |  TAB  |   | BSPC  |  SPC  |  DEL  |
ZMK_COMBO(cut, &kp LC(X), LB1 LB2, DEF, COMBO_TERM_SLOW)

// UNDO
// -----------------------------------------------------------------------------------------
// tap      |   Q   |XXXWXXX|XXXEXXX|   R   |   T   |   |   Y   |   U   |   I   |   O   |   P   |
//          _____________________________________________________________________________________
// tap      |   A   |   S   |   D   |   F   |   G   |   |   H   |   J   |   K   |   L   |   ;   |
//          _____________________________________________________________________________________
// tap      |   Z   |   X   |   C   |   V   |   B   |   |   N   |   M   |   ,   |   .   |   /   |
//
// tap                      |  ESC  |  ENT  |  TAB  |   | BSPC  |  SPC  |  DEL  |
ZMK_COMBO(undo, &kp LC(Z), LT1 LT2, DEF, COMBO_TERM_SLOW)

// REDO
// -----------------------------------------------------------------------------------------
// tap      |   Q   |   W   |XXXEXXX|XXXRXXX|   T   |   |   Y   |   U   |   I   |   O   |   P   |
//          _____________________________________________________________________________________
// tap      |   A   |   S   |   D   |   F   |   G   |   |   H   |   J   |   K   |   L   |   ;   |
//          _____________________________________________________________________________________
// tap      |   Z   |   X   |   C   |   V   |   B   |   |   N   |   M   |   ,   |   .   |   /   |
//
// tap                      |  ESC  |  ENT  |  TAB  |   | BSPC  |  SPC  |  DEL  |
ZMK_COMBO(redo, &kp LC(Y), LT2 LT3, DEF, COMBO_TERM_SLOW)

// APOSTROPHE
// -----------------------------------------------------------------------------------------
// tap      |   Q   |   W   |   E   |   R   |   T   |   |   Y   |   U   |   I   |   O   |   P   |
//          ___________________________________________________________________
// tap      |   A   |   S   |   D   |   F   |   G   |   |   H   |   J   |   K   |XXXLXXX|XXX;XXX|
//          ___________________________________________________________________
// tap      |   Z   |   X   |   C   |   V   |   B   |   |   N   |   M   |   ,   |   .   |   /   |
//
// tap                      |  ESC  |  ENT  |  TAB  |   | BSPC  |  SPC  |  DEL  |
ZMK_COMBO(apos, &kp APOS, RM1 RM0, DEF, COMBO_TERM_SLOW)



&mt {
    flavor = "balanced";
    tapping-term-ms = <250>;
    quick-tap-ms = <175>;
};

/ {
    keymap {
        compatible = "zmk,keymap";

        default_layer {
            display-name = "Base";
            bindings = <
    &kp Q      &kp W      &kp E       &kp R          &kp T                                    &kp Y          &kp U          &kp I       &kp O      &kp P
    &kp A      &mt LALT S &mt LCTRL D &mt LSHFT F    &kp G                                    &kp H          &mt RSHFT J    &mt RCTRL K &mt RALT L &kp SEMI
    &mt LGUI Z &kp X      &kp C       &kp V          &kp B                                    &kp N          &kp M          &kp COMMA   &kp DOT    &mt RGUI FSLH
               &kp LSHIFT &lt MED ESC &lt NAV ENT    &lt MOU TAB   &lt SYM BSPC  &lt NUM SPACE &lt FUN DEL    &mkp LCLK      &mkp RCLK
            >;
        };

        nav_layer {
            display-name = "Nav";
            bindings = <
    &none      &none      &none       &none          &none                                    &kp PG_UP      &kp HOME       &kp UP      &kp END    &kp CAPS
    &none      &kp LALT   &kp LCTRL   &kp LSHFT      &none                                    &kp PG_DN      &kp LEFT       &kp DOWN    &kp RIGHT  &kp DEL
    &none      &none      &none       &none          &none                                    &none          &none          &none       &none      &none
               &trans     &trans      &trans         &trans        &trans        &trans       &trans         &trans         &trans
            >;
        };

        sym_layer {
            display-name = "Sym";
            bindings = <
    &kp LBRC   &kp AMPS   &kp ASTRK   &kp LPAR       &kp RBRC                                 &none          &none          &none       &none      &none
    &kp COLON  &kp DLLR   &kp PRCNT   &kp CARET      &kp PLUS                                 &none          &kp RSHFT      &kp RCTRL   &kp RALT   &none
    &kp TILDE  &kp EXCL   &kp AT      &kp HASH       &kp PIPE                                 &none          &none          &none       &none      &none
               &trans     &kp LPAR    &kp RPAR       &kp UNDER     &trans        &trans       &trans         &trans         &trans
            >;
        };

        num_layer {
            display-name = "Num";
            bindings = <
    &kp LBKT   &kp N7     &kp N8      &kp N9         &kp RBKT                                 &none          &none          &none       &none      &none
    &kp SQT    &kp N4     &kp N5      &kp N6         &kp EQUAL                                &none          &kp RSHFT      &kp RCTRL   &kp RALT   &none
    &kp GRAVE  &kp N1     &kp N2      &kp N3         &kp BSLH                                 &none          &none          &none       &none      &none
               &trans     &kp DOT     &kp N0         &kp MINUS     &trans        &trans       &trans         &trans         &trans
            >;
        };

        fun_layer {
            display-name = "Fun";
            bindings = <
    &kp F12    &kp F7     &kp F8      &kp F9         &kp PSCRN                                &none          &none          &none       &none      &none
    &kp F11    &kp F4     &kp F5      &kp F6         &kp SLCK                                 &none          &kp RSHFT      &kp RCTRL   &kp RALT   &none
    &kp F10    &kp F1     &kp F2      &kp F3         &kp PAUSE                                &none          &none          &none       &none      &none
               &trans     &kp K_APP   &trans         &trans        &trans        &trans       &trans         &trans         &trans
            >;
        };

        mou_layer {
            display-name = "Mouse";
            bindings = <
    &none      &none      &none       &none          &none                                    &none          &none          &none       &none      &none
    &none      &kp LALT   &kp LCTRL   &kp LSHFT      &none                                    &none          &mkp LCLK      &mkp MCLK   &mkp RCLK  &none
    &none      &none      &none       &none          &none                                    &none          &mkp MB4       &none       &mkp MB5   &none
               &trans     &trans      &trans         &trans        &trans        &trans       &trans         &trans         &trans
            >;
        };

        med_layer {
            display-name = "Media";
            bindings = <
    &bt BT_CLR &bt BT_SEL 0 &bt BT_SEL 1 &bt BT_SEL 2 &bt BT_SEL 3                            &none          &none          &none       &none      &none
    &none      &kp LALT     &kp LCTRL    &kp LSHFT    &none                                   &none          &kp C_PREV     &kp C_VOL_DN &kp C_VOL_UP &kp C_NEXT
    &none      &none        &none        &none        &none                                   &none          &none          &none       &none      &none
               &trans       &trans       &trans       &kp C_STOP    &kp C_PP      &kp C_MUTE  &trans         &trans         &trans
            >;
        };
    };
};
